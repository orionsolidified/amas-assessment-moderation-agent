{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orionsolidified.io/schemas/amas/intake.schema.json",
  "title": "AMAS Case Intake",
  "type": "object",
  "required": ["title", "module_code", "assessment_type", "artifacts", "learning_outcomes"],
  "properties": {
    "case_id": {"type": "string", "format": "uuid"},
    "external_ref": {"type": ["string", "null"], "maxLength": 200},
    "tenant_id": {"type": "string", "default": "default", "maxLength": 100},
    "idempotency_key": {"type": ["string", "null"], "maxLength": 200},
    "title": {"type": "string", "minLength": 3, "maxLength": 500},
    "module_code": {"type": "string", "minLength": 1, "maxLength": 100},
    "module_title": {"type": ["string", "null"], "maxLength": 500},
    "study_level": {"type": ["string", "number", "null"]},
    "credit_value": {"type": ["number", "null"], "minimum": 0},
    "assessment_weight": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
    "assessment_type": {"type": "string", "minLength": 1},
    "individual_or_group": {"enum": ["individual", "group", "mixed", null]},
    "formative_or_summative": {"enum": ["formative", "summative", "both", null]},
    "issue_date": {"type": ["string", "null"], "format": "date"},
    "submission_date": {"type": ["string", "null"], "format": "date"},
    "submitter_id": {"type": ["string", "null"]},
    "moderator_id": {"type": ["string", "null"]},
    "declared_ai_mode": {"enum": ["closed", "guided", "open", "unspecified", null]},
    "evaluation_mode": {"type": "boolean", "default": false},
    "metadata": {"type": "object", "additionalProperties": true},
    "learning_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["outcome_code", "description"],
        "properties": {
          "outcome_code": {"type": "string"},
          "description": {"type": "string"},
          "level_descriptor": {"type": ["string", "null"]},
          "metadata": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["artifact_type", "extracted_text"],
        "properties": {
          "artifact_type": {
            "enum": ["assessment_brief", "rubric", "module_descriptor", "programme_specification", "policy", "supporting_document"]
          },
          "original_filename": {"type": ["string", "null"]},
          "mime_type": {"type": ["string", "null"]},
          "size_bytes": {"type": ["integer", "null"], "minimum": 0},
          "storage_bucket": {"type": ["string", "null"]},
          "storage_key": {"type": ["string", "null"]},
          "sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
          "extracted_text": {"type": "string"},
          "text_sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
          "extraction_status": {"type": "string", "default": "provided"},
          "metadata": {"type": "object", "additionalProperties": true}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
