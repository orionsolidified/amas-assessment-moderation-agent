{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListAMASBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::amas"]
    },
    {
      "Sid": "ReadWriteAMASObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:GetObjectTagging", "s3:PutObjectTagging"],
      "Resource": ["arn:aws:s3:::amas/originals/*", "arn:aws:s3:::amas/reports/*", "arn:aws:s3:::amas/knowledge/*", "arn:aws:s3:::amas/evals/*"]
    }
  ]
}
