# Public URLs
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/
N8N_INTERNAL_BASE_URL=http://n8n:5678
AMAS_INTAKE_PUBLIC_URL=http://localhost:8080
AMAS_INTAKE_INTERNAL_URL=http://intake-api:8080

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_OWNER_PASSWORD
AMAS_APP_PASSWORD=CHANGE_ME_AMAS_APP_PASSWORD
AMAS_READONLY_PASSWORD=CHANGE_ME_AMAS_READONLY_PASSWORD
AMAS_DATABASE_URL=postgresql://amas_app:CHANGE_ME_AMAS_APP_PASSWORD@postgres:5432/n8n

# n8n
N8N_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_RANDOM_ENCRYPTION_KEY
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_JWT_SECRET
GENERIC_TIMEZONE=Asia/Colombo
AMAS_API_TOKEN=CHANGE_ME_LONG_RANDOM_PUBLIC_API_TOKEN
AMAS_INTERNAL_TOKEN=CHANGE_ME_LONG_RANDOM_INTERNAL_TOKEN
AMAS_EVAL_TOKEN=CHANGE_ME_LONG_RANDOM_EVAL_TOKEN
AMAS_WORKFLOW_VERSION=amas-1.0.0
AMAS_CORPUS_VERSION=policy-corpus-demo-1.0

# S3-compatible object storage (Garage local profile)
GARAGE_RPC_SECRET=CHANGE_ME_64_HEX_RPC_SECRET
GARAGE_ADMIN_TOKEN=CHANGE_ME_GARAGE_ADMIN_TOKEN
GARAGE_METRICS_TOKEN=CHANGE_ME_GARAGE_METRICS_TOKEN
S3_ENDPOINT=http://garage:3900
S3_PUBLIC_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=amas
S3_ACCESS_KEY=GKCHANGE_ME_32_HEX
S3_SECRET_KEY=CHANGE_ME_64_HEX

# AnythingLLM. Use the exact API base of your instance.
ANYTHINGLLM_BASE_URL=https://anythingllm.example.edu
ANYTHINGLLM_API_KEY=CHANGE_ME_ANYTHINGLLM_API_KEY
ANYTHINGLLM_WORKSPACE_SLUG=assessment-moderation-authoritative

# OpenAI-compatible model gateway. LiteLLM is recommended when mixing Claude/OpenAI/local models.
LLM_BASE_URL=https://llm-gateway.example.edu/v1
LLM_API_KEY=CHANGE_ME_LLM_GATEWAY_KEY
LLM_PRIMARY_MODEL=moderation-primary
LLM_CRITIC_MODEL=moderation-critic
LLM_PROVIDER_NAME=litellm

# Intake API
AMAS_MAX_FILE_BYTES=26214400
